{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Clipboard Manager",
  "version": "0.1.0",
  "identifier": "co.codebuddy.clipboardmanager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "popup",
        "title": "Clipboard Manager",
        "url": "index.html",
        "width": 680,
        "height": 520,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "focus": false,
        "resizable": false,
        "center": true
      },
      {
        "label": "settings",
        "title": "Clipboard Manager — Settings",
        "url": "index.html",
        "width": 720,
        "height": 560,
        "decorations": true,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "infoPlist": "Info.plist"
    }
  }
}
